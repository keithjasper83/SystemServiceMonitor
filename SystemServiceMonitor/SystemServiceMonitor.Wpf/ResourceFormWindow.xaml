<Window x:Class="SystemServiceMonitor.Wpf.ResourceFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add/Edit Resource" Height="550" Width="400" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Resource Configuration" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="FormPanel">
                <TextBlock Text="Display Name" />
                <TextBox x:Name="TxtDisplayName" Margin="0,0,0,10" />

                <TextBlock Text="Type" />
                <ComboBox x:Name="CboType" Margin="0,0,0,10" SelectionChanged="CboType_SelectionChanged" />

                <TextBlock Text="Start Command" />
                <TextBox x:Name="TxtStartCommand" Margin="0,0,0,10" />

                <TextBlock Text="Stop Command" />
                <TextBox x:Name="TxtStopCommand" Margin="0,0,0,10" />

                <TextBlock Text="Restart Command" />
                <TextBox x:Name="TxtRestartCommand" Margin="0,0,0,10" />

                <TextBlock Text="Healthcheck URL/Command" />
                <TextBox x:Name="TxtHealthcheck" Margin="0,0,0,10" />

                <TextBlock Text="Working Directory" />
                <TextBox x:Name="TxtWorkingDir" Margin="0,0,0,10" />

                <TextBlock Text="WSL Distro (If applicable)" />
                <TextBox x:Name="TxtWslDistro" Margin="0,0,0,10" />

                <TextBlock Text="Docker Identifier (If applicable)" />
                <TextBox x:Name="TxtDockerId" Margin="0,0,0,10" />

                <TextBlock Text="Dependency IDs (Comma separated)" />
                <TextBox x:Name="TxtDependencies" Margin="0,0,0,10" />

                <TextBlock Text="GitHub Repo URL (Optional)" />
                <TextBox x:Name="TxtGitHubRepo" Margin="0,0,0,10" />

                <CheckBox x:Name="ChkAutoRepair" Content="Auto Repair Enabled" Margin="0,0,0,10" IsChecked="True" />
                <CheckBox x:Name="ChkRequiresElevation" Content="Requires Elevation" Margin="0,0,0,10" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cancel" Width="75" Margin="0,0,10,0" Click="BtnCancel_Click" />
            <Button Content="Save" Width="75" Click="BtnSave_Click" />
        </StackPanel>
    </Grid>
</Window>
